# Domaine public pointe vers l'IP du serveur, sans http:// ni https://
DOMAIN_NAME=budgie.example.com

# URL publique utilisee dans les emails
APP_URL=https://budgie.example.com
APP_ENV=production

# Email Configuration (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@budgie.example.com
SMTP_FROM_NAME=Budgie

# Base de donnees SQLite persistante dans ./data/budgie.db
DATABASE_PATH=data/budgie.db

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PREMIUM_PRICE_ID=
